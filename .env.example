# Alla nycklar är VALFRIA - de skrapas automatiskt från kedjornas publika sidor.
# Sätt bara om du vill tvinga en egen nyckel istället för auto-skrapning.

ICA_TOKEN=         # publicAccessToken, annars hämtas från ica.se/e11/public-access-token
COOP_KEY=          # butiks-API (storeApiSubscriptionKey), annars env + scrape-on-401
COOP_OFFERS_KEY=   # offers-API (dkeKey), annars scrape-on-401
LIDL_KEY=          # x-apikey, annars env + scrape-on-401
# Willys + Hemköp kräver ingen nyckel

# Schemalagd butikssynk via cron (default dagligen 04:00 svensk tid, tomt = av)
# Exempel: "0 4 * * *" = 04:00 dagligen, "0 */6 * * *" = var 6:e timme
SYNC_CRON=0 4 * * *
SYNC_TZ=Europe/Stockholm
